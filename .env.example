# ──────────────────────────────────────────────────────────────────
# Arcana — Environment Variables
# Copy this to .env and fill in your values.
# You only need ONE LLM provider configured.
# ──────────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────────
# SQLite (default, no config needed)
DATABASE_URL="file:./dev.db"

# ── LLM Provider (choose one) ────────────────────────────────────

# Option 1: OpenAI direct
# OPENAI_API_KEY=sk-...

# Option 2: Anthropic direct
# ANTHROPIC_API_KEY=sk-ant-...

# Option 3: OpenAI-compatible endpoint (OpenRouter, LiteLLM, Azure, custom)
# LLM_PROXY_URL=https://openrouter.ai/api/v1
# LLM_PROXY_HEADER_NAME=Authorization
# LLM_PROXY_HEADER_VALUE=Bearer sk-or-...

# ── External Services (optional) ─────────────────────────────────

# Semantic Scholar API key (higher rate limits for paper search)
# S2_API_KEY=

# CrossRef mailto (for polite API access, defaults to paperfinder@localhost)
# CROSSREF_MAILTO=your@email.com

# GROBID Service (reference extraction)
# GROBID_SERVER_URL=http://localhost:8070
# GROBID_INTERACTIVE_CONCURRENCY=1
# GROBID_BACKFILL_CONCURRENCY=2
# GROBID_MAX_QUEUE_DEPTH=50
# GROBID_BASE_DEADLINE_MS=30000
# GROBID_PER_PAGE_DEADLINE_MS=2000
# GROBID_CB_THRESHOLD=5
# GROBID_CB_WINDOW_MS=60000
# GROBID_CB_COOLDOWN_MS=30000
# GROBID_MAX_RETRIES=2
