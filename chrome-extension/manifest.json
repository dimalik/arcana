{
  "manifest_version": 3,
  "name": "Arcana Import",
  "version": "1.0.0",
  "description": "Import papers from arXiv, OpenReview, and PDF pages directly into Arcana",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["activeTab", "storage", "scripting", "webNavigation"],
  "host_permissions": ["http://localhost:3000/*", "<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://arxiv.org/abs/*", "*://arxiv.org/pdf/*"],
      "js": ["content-arxiv.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://openreview.net/forum*", "*://openreview.net/pdf*"],
      "js": ["content-openreview.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://*/*.pdf", "*://*/*.pdf?*", "file:///*/*.pdf"],
      "js": ["content-pdf.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": [
        "viewer.html",
        "viewer.css",
        "viewer.js",
        "lib/pdfjs/pdf.min.mjs",
        "lib/pdfjs/pdf.worker.min.mjs"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
