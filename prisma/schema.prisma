  asset            Asset                    @relation("RenderedPreviewAsset", fields: [assetId], references: [id], onDelete: Cascade)
  selectedBy       PreviewSelectionFigure[] @relation("SelectedRenderedPreview")

  @@unique([renderRunId, projectionFigureId])
  @@index([projectionFigureId])
  @@index([assetId])
}

model PaperPublicationState {
  id                          String   @id @default(uuid())
