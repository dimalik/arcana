  @@index([projectionRunId])
  @@index([supersedesPreviewSelectionRunId])
}

model PreviewSelectionFigure {
  id                          String   @id @default(uuid())
  previewSelectionRunId       String
  projectionFigureId          String
  selectedPreviewSource       String
  selectedPreviewSourceMethod String?
  selectedAssetId             String?
  selectedRenderedPreviewId   String?
  selectedNativeCandidateId   String?
