  paperId              String   @unique
  latestBootstrapRunId String?
  migrationState       String
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  paper              Paper                          @relation(fields: [paperId], references: [id], onDelete: Cascade)
  latestBootstrapRun LegacyPublicationBootstrapRun? @relation("LatestBootstrapRun", fields: [latestBootstrapRunId], references: [id], onDelete: SetNull)

  @@index([latestBootstrapRunId])
}

model FigureOverride {
  id            String    @id @default(uuid())
  paperId       String
  overrideType  String
  overrideStage String
  selectorType  String
  selectorValue String
  payload       String?
  reason        String?
  createdBy     String?
  status        String    @default("active")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  disabledAt    DateTime?

  paper Paper @relation(fields: [paperId], references: [id], onDelete: Cascade)

  @@index([paperId, status, overrideStage])
  @@index([paperId, selectorType, selectorValue, status])
}

model PaperWorkLease {
