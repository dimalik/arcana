  @@index([paperId, bootstrapRunId])
  @@index([paperId, figureLabelNormalized])
  @@index([nativeAssetId])
}

model LegacyPublicationBootstrapRun {
  id          String    @id @default(uuid())
  paperId     String
  status      String
  metadata    String?
  createdAt   DateTime  @default(now())
  completedAt DateTime?

  paper                    Paper                 @relation(fields: [paperId], references: [id], onDelete: Cascade)
