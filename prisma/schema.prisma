generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ── Auth & Observability ─────────────────────────────────────────

model User {
  id           String  @id @default(uuid())
  email        String  @unique
  passwordHash String?
  name         String?
  role         String  @default("member") // "admin" | "member"
  avatarUrl    String?

  // Research profile (set during onboarding, editable in profile)
  researchRole   String? // "phd_student" | "postdoc" | "professor" | "industry_researcher" | "engineer" | "student" | "other"
  affiliation    String?
  domains        String? // JSON array of research domains e.g. ["nlp", "computer-vision"]
  expertiseLevel String? // "beginner" | "intermediate" | "expert"
  reviewFocus    String? // JSON array e.g. ["methodology", "novelty", "applications", "reproducibility"]
  scholarUrl     String? // Google Scholar profile URL for seeding

  onboardingCompleted Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions                 UserSession[]
  llmUsageLogs             LlmUsageLog[]
  appEvents                AppEvent[]
  papers                   Paper[]
  researchProjects         ResearchProject[]
  discoverySessions        DiscoverySession[]
  agentCapabilities        AgentCapability[]
  agentMemories            AgentMemory[]
  paperDuplicateCandidates PaperDuplicateCandidate[]
}

model UserSession {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model LlmUsageLog {
  id               String   @id @default(uuid())
  userId           String?
  provider         String // "openai" | "anthropic" | "proxy"
  modelId          String
  operation        String // "summarize" | "extract" | "chat" | "synthesis" | etc.
  inputTokens      Int      @default(0)
  outputTokens     Int      @default(0)
  totalTokens      Int      @default(0)
  estimatedCostUsd Float    @default(0)
  durationMs       Int      @default(0)
  success          Boolean  @default(true)
  error            String?
  metadata         String? // JSON: paperId, sessionId, extra context
  createdAt        DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([createdAt])
  @@index([operation])
  @@index([modelId])
}

model AppEvent {
  id        String   @id @default(uuid())
  userId    String?
  level     String // "error" | "warn" | "info"
  category  String // "llm" | "api" | "import" | "synthesis" | "auth" | "system"
  message   String
  metadata  String? // JSON: stack trace, request path, paper ID, etc.
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([level])
  @@index([category])
  @@index([createdAt])
}

// ── Core Models ──────────────────────────────────────────────────

model PaperEntity {
  id       String  @id @default(uuid())
  title    String
  authors  String? // JSON array — best-known authors
  year     Int?
  venue    String?
  abstract String?

  titleSource   String?
  authorsSource String?
  yearSource    String?
  venueSource   String?

  mergedIntoEntityId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  mergedInto         PaperEntity?               @relation("EntityMerge", fields: [mergedIntoEntityId], references: [id])
  mergedFrom         PaperEntity[]              @relation("EntityMerge")
  identifiers        PaperIdentifier[]
  papers             Paper[]
  discoveryProposals DiscoveryProposal[]
  candidateLinksA    PaperEntityCandidateLink[] @relation("CandidateA")
  candidateLinksB    PaperEntityCandidateLink[] @relation("CandidateB")
  resolvedReferences ReferenceEntry[]           @relation("ResolvedEntity")
  sourceAssertions   RelationAssertion[]        @relation("AssertionSource")
  targetAssertions   RelationAssertion[]        @relation("AssertionTarget")

  @@index([mergedIntoEntityId])
}

model PaperIdentifier {
  id         String   @id @default(uuid())
  entityId   String
  type       String
  value      String
  raw        String?
  source     String
  confidence Float    @default(1.0)
  createdAt  DateTime @default(now())

  entity PaperEntity @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@unique([type, value])
  @@index([entityId])
}

model PaperEntityCandidateLink {
  id         String    @id @default(uuid())
  entityAId  String
  entityBId  String
  reason     String
  confidence Float
  status     String    @default("PENDING")
  createdAt  DateTime  @default(now())
  resolvedAt DateTime?

  entityA PaperEntity @relation("CandidateA", fields: [entityAId], references: [id], onDelete: Cascade)
  entityB PaperEntity @relation("CandidateB", fields: [entityBId], references: [id], onDelete: Cascade)

  @@unique([entityAId, entityBId])
  @@index([status])
}

// ── Citation Graph Layer ─────────────────────────────────────────

model ReferenceEntry {
  id                String   @id @default(uuid())
  paperId           String
  referenceIndex    Int?
  rawCitation       String
  title             String
  authors           String? // JSON array
  year              Int?
  venue             String?
  doi               String?
  arxivId           String?
  externalUrl       String?
  semanticScholarId String?
  resolvedEntityId  String?
  resolveConfidence Float?
  resolveSource     String?
  provenance        String   @default("llm_extraction")
  extractorVersion  String?
  legacyReferenceId String?  @unique
  createdAt         DateTime @default(now())

  paper            Paper              @relation("ReferenceEntries", fields: [paperId], references: [id], onDelete: Cascade)
  resolvedEntity   PaperEntity?       @relation("ResolvedEntity", fields: [resolvedEntityId], references: [id], onDelete: SetNull)
  citationMentions CitationMention[]
  evidence         RelationEvidence[]

  @@index([paperId])
  @@index([resolvedEntityId])
}

model CitationMention {
  id               String   @id @default(uuid())
  paperId          String
  referenceEntryId String
  sectionLabel     String?
  page             Int?
  charStart        Int?
  charEnd          Int?
  excerpt          String
  citationText     String
  rhetoricalRole   String?
  provenance       String   @default("llm_extraction")
  extractorVersion String?
  createdAt        DateTime @default(now())

  paper          Paper              @relation("CitationMentions", fields: [paperId], references: [id], onDelete: Cascade)
  referenceEntry ReferenceEntry     @relation(fields: [referenceEntryId], references: [id], onDelete: Cascade)
  evidence       RelationEvidence[]

  @@index([paperId])
  @@index([referenceEntryId])
}

// ── Assertion Graph Layer ────────────────────────────────────────

model RelationAssertion {
  id               String   @id @default(uuid())
  sourceEntityId   String
  targetEntityId   String
  sourcePaperId    String?
  relationType     String
  description      String?
  confidence       Float    @default(0.0)
  provenance       String
  extractorVersion String?
  createdByUserId  String?
  createdAt        DateTime @default(now())

  sourceEntity PaperEntity        @relation("AssertionSource", fields: [sourceEntityId], references: [id], onDelete: Cascade)
  targetEntity PaperEntity        @relation("AssertionTarget", fields: [targetEntityId], references: [id], onDelete: Cascade)
  sourcePaper  Paper?             @relation("DerivedAssertions", fields: [sourcePaperId], references: [id], onDelete: SetNull)
  evidence     RelationEvidence[]

  @@unique([sourcePaperId, targetEntityId, relationType, provenance])
  @@index([sourceEntityId, targetEntityId])
  @@index([sourcePaperId])
  @@index([relationType])
}

model RelationEvidence {
  id                String   @id @default(uuid())
  assertionId       String
  type              String
  excerpt           String?
  citationMentionId String?
  referenceEntryId  String?
  createdAt         DateTime @default(now())

  assertion       RelationAssertion @relation(fields: [assertionId], references: [id], onDelete: Cascade)
  citationMention CitationMention?  @relation(fields: [citationMentionId], references: [id], onDelete: SetNull)
  referenceEntry  ReferenceEntry?   @relation(fields: [referenceEntryId], references: [id], onDelete: SetNull)

  @@index([assertionId])
  @@index([citationMentionId])
}

enum PaperDuplicateState {
  ACTIVE
  HIDDEN
  ARCHIVED
  COLLAPSED
}

enum PaperDuplicateClass {
  EXACT_IDENTIFIER
  FUZZY
}

enum PaperDuplicateReviewStatus {
  PENDING
  ACCEPTED
  DISMISSED
  APPLIED
}

enum PaperDuplicateAction {
  HIDE
  ARCHIVE
  COLLAPSE
}

enum PaperClaimRunStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum PaperClaimRhetoricalRole {
  BACKGROUND
  MOTIVATION
  RESEARCH_QUESTION
  HYPOTHESIS
  DEFINITION
  ASSUMPTION
  METHOD
  DATASET
  RESULT
  EVALUATION
  LIMITATION
  FUTURE_WORK
  CONTRIBUTION
}

enum PaperClaimFacet {
  PROBLEM
  APPROACH
  RESULT
  COMPARISON
  LIMITATION
  RESOURCE
}

enum PaperClaimPolarity {
  ASSERTIVE
  NEGATED
  CONDITIONAL
  SPECULATIVE
}

enum PaperClaimEvidenceType {
  PRIMARY
  SECONDARY
  CITING
}

enum ConversationArtifactKind {
  CLAIM_LIST
  CONTRADICTION_TABLE
  GAP_LIST
  TIMELINE
  METHODOLOGY_COMPARE
  RESULT_SUMMARY
  FIGURE_CARD
  TABLE_CARD
  CODE_SNIPPET
}

model Paper {
  id                   String              @id @default(uuid())
  userId               String?
  title                String
  abstract             String?
  authors              String? // JSON array as string
  year                 Int?
  venue                String?
  doi                  String?
  sourceType           String              @default("UPLOAD") // UPLOAD, ARXIV, URL
  sourceUrl            String?
  arxivId              String?
  filePath             String?
  fullText             String?
  summary              String?
  keyFindings          String? // JSON array as string
  categories           String? // JSON array as string
  processingStatus     String              @default("PENDING") // PENDING, EXTRACTING_TEXT, TEXT_EXTRACTED, COMPLETED, FAILED
  processingStep       String? // Current step: "extracting_text", "metadata", "summarize", "categorize", "linking", "references", "contexts"
  processingStartedAt  DateTime? // When current processing began — for stall detection
  referenceState       String              @default("pending") // available | pending | extraction_failed | unavailable_no_pdf
  citationCount        Int?
  isLiked              Boolean             @default(false)
  isResearchOnly       Boolean             @default(false) // true = imported by research agent, hidden from main library
  engagementScore      Float               @default(0)
  duplicateState       PaperDuplicateState @default(ACTIVE)
  collapsedIntoPaperId String?
  entityId             String?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  owner                          User?                           @relation(fields: [userId], references: [id], onDelete: SetNull)
  collapsedIntoPaper             Paper?                          @relation("PaperCollapse", fields: [collapsedIntoPaperId], references: [id], onDelete: SetNull)
  collapsedPapers                Paper[]                         @relation("PaperCollapse")
  entity                         PaperEntity?                    @relation(fields: [entityId], references: [id], onDelete: SetNull)
  tags                           PaperTag[]
  collections                    CollectionPaper[]
  chatMessages                   ChatMessage[]
  promptResults                  PromptResult[]
  sourceRelations                PaperRelation[]                 @relation("SourceRelations")
  targetRelations                PaperRelation[]                 @relation("TargetRelations")
  references                     Reference[]
  matchedBy                      Reference[]                     @relation("MatchedReferences")
  conversations                  Conversation[]
  conversationPapers             ConversationPaper[]
  notebookEntries                NotebookEntry[]
  discoverySeeds                 DiscoverySeed[]
  discoveryImports               DiscoveryProposal[]
  engagements                    PaperEngagement[]
  insights                       Insight[]
  agentSessions                  AgentSession[]
  synthesisPapers                SynthesisPaper[]
  figures                        PaperFigure[]
  figureAssets                   Asset[]
  sourceCapabilityEvaluations    SourceCapabilityEvaluation[]
  capabilitySnapshots            CapabilitySnapshot[]
  extractionRuns                 ExtractionRun[]
  legacyPublicationBootstrapRuns LegacyPublicationBootstrapRun[]
  figureCandidates               FigureCandidate[]
  identityResolutions            IdentityResolution[]
  figureIdentities               FigureIdentity[]
  projectionRuns                 ProjectionRun[]
  previewSelectionRuns           PreviewSelectionRun[]
  renderRuns                     RenderRun[]
  publishedFigureHandles         PublishedFigureHandle[]
  figureOverrides                FigureOverride[]
  publicationState               PaperPublicationState?
  migrationState                 PaperMigrationState?
  workLease                      PaperWorkLease?
  claimEvidence                  ClaimEvidence[]
  referenceEntries               ReferenceEntry[]                @relation("ReferenceEntries")
  citationMentions               CitationMention[]               @relation("CitationMentions")
  derivedAssertions              RelationAssertion[]             @relation("DerivedAssertions")
  processingRuns                 ProcessingRun[]
  processingStepRuns             ProcessingStepRun[]
  claimRuns                      PaperClaimRun[]
  claims                         PaperClaim[]
  representations                PaperRepresentation[]
  paperAuthors                   PaperAuthor[]
  wonDuplicateCandidates         PaperDuplicateCandidate[]       @relation("DuplicateCandidateWinner")
  lostDuplicateCandidates        PaperDuplicateCandidate[]       @relation("DuplicateCandidateLoser")

  @@unique([userId, entityId])
  @@index([userId, duplicateState])
  @@index([collapsedIntoPaperId])
}

model PaperDuplicateCandidate {
  id                       String                     @id @default(uuid())
  userId                   String
  winnerPaperId            String
  loserPaperId             String
  duplicateClass           PaperDuplicateClass
  score                    Float
  evidenceJson             String
  reviewStatus             PaperDuplicateReviewStatus @default(PENDING)
  chosenAction             PaperDuplicateAction?
  autoSafeCollapse         Boolean                    @default(false)
  canonicalEntityCollision Boolean                    @default(false)
  reviewedAt               DateTime?
  appliedAt                DateTime?
  createdAt                DateTime                   @default(now())
  updatedAt                DateTime                   @updatedAt

  user        User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  winnerPaper Paper @relation("DuplicateCandidateWinner", fields: [winnerPaperId], references: [id], onDelete: Cascade)
  loserPaper  Paper @relation("DuplicateCandidateLoser", fields: [loserPaperId], references: [id], onDelete: Cascade)

  @@unique([winnerPaperId, loserPaperId])
  @@index([userId, reviewStatus])
  @@index([userId, duplicateClass])
  @@index([loserPaperId])
}

model AgentSession {
  id           String    @id @default(uuid())
  paperId      String
  templateId   String?
  customPrompt String?
  mode         String    @default("analyze")
  status       String    @default("PENDING") // PENDING | RUNNING | COMPLETED | FAILED | CANCELLED
  events       String    @default("[]") // JSON array of AgentEvent objects
  costUsd      Float?
  durationMs   Int?
  turns        Int?
  error        String?
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime  @default(now())
  paper        Paper     @relation(fields: [paperId], references: [id], onDelete: Cascade)

  @@index([paperId])
}

model TagCluster {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  color       String   @default("#6B7280")
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  tags        Tag[]
}

model Tag {
  id              String   @id @default(uuid())
  name            String   @unique
  color           String   @default("#6B7280")
  isAutoGenerated Boolean  @default(false)
  score           Float    @default(0)
  clusterId       String?
  createdAt       DateTime @default(now())

  cluster TagCluster? @relation(fields: [clusterId], references: [id], onDelete: SetNull)
  papers  PaperTag[]

  @@index([clusterId])
}

model PaperTag {
  id      String @id @default(uuid())
  paperId String
  tagId   String

  paper Paper @relation(fields: [paperId], references: [id], onDelete: Cascade)
  tag   Tag   @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([paperId, tagId])
}

model Collection {
  id          String   @id @default(uuid())
  name        String
  description String?
  parentId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  parent          Collection?       @relation("CollectionTree", fields: [parentId], references: [id])
  children        Collection[]      @relation("CollectionTree")
  papers          CollectionPaper[]
  researchProject ResearchProject?
}

model CollectionPaper {
  id           String @id @default(uuid())
  paperId      String
  collectionId String

  paper      Paper      @relation(fields: [paperId], references: [id], onDelete: Cascade)
  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@unique([paperId, collectionId])
}

model ChatMessage {
  id             String   @id @default(uuid())
  paperId        String
  role           String // user, assistant, system
  content        String
  metadataJson   String?
  provider       String?
  model          String?
  conversationId String?
  createdAt      DateTime @default(now())

  paper        Paper                  @relation(fields: [paperId], references: [id], onDelete: Cascade)
  conversation Conversation?          @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  artifacts    ConversationArtifact[]
}

model PromptResult {
  id         String   @id @default(uuid())
  paperId    String
  promptType String // summarize, extract, categorize, code, custom
  prompt     String
  result     String
  provider   String?
  model      String?
  createdAt  DateTime @default(now())

  paper Paper @relation(fields: [paperId], references: [id], onDelete: Cascade)
}

model PaperRelation {
  id              String   @id @default(uuid())
  sourcePaperId   String
  targetPaperId   String
  relationType    String
  description     String?
  confidence      Float    @default(0.0)
  isAutoGenerated Boolean  @default(false)
  createdAt       DateTime @default(now())

  sourcePaper Paper @relation("SourceRelations", fields: [sourcePaperId], references: [id], onDelete: Cascade)
  targetPaper Paper @relation("TargetRelations", fields: [targetPaperId], references: [id], onDelete: Cascade)

  @@unique([sourcePaperId, targetPaperId])
}

model Reference {
  id                String   @id @default(uuid())
  paperId           String
  title             String
  authors           String? // JSON array as string
  year              Int?
  venue             String?
  doi               String?
  rawCitation       String
  referenceIndex    Int?
  matchedPaperId    String?
  matchConfidence   Float?
  citationContext   String? // LLM-extracted: why this paper is cited
  semanticScholarId String? // S2 paper ID for linking
  arxivId           String? // arXiv ID if discovered during enrichment
  externalUrl       String? // Best external URL (S2, DOI, arXiv)
  createdAt         DateTime @default(now())

  paper        Paper  @relation(fields: [paperId], references: [id], onDelete: Cascade)
  matchedPaper Paper? @relation("MatchedReferences", fields: [matchedPaperId], references: [id], onDelete: SetNull)
}

model Conversation {
  id           String   @id @default(uuid())
  paperId      String
  title        String?
  selectedText String?
  mode         String? // "explain" | "chat"
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  paper            Paper                  @relation(fields: [paperId], references: [id], onDelete: Cascade)
  messages         ChatMessage[]
  additionalPapers ConversationPaper[]
  notebookEntries  NotebookEntry[]
  artifacts        ConversationArtifact[]
}

model ConversationPaper {
  id             String @id @default(uuid())
  conversationId String
  paperId        String

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  paper        Paper        @relation(fields: [paperId], references: [id], onDelete: Cascade)

  @@unique([conversationId, paperId])
}

model PaperClaimRun {
  id               String              @id @default(uuid())
  paperId          String
  extractorVersion String
  status           PaperClaimRunStatus @default(PENDING)
  sourceTextHash   String
  createdAt        DateTime            @default(now())
  completedAt      DateTime?

  paper  Paper        @relation(fields: [paperId], references: [id], onDelete: Cascade)
  claims PaperClaim[]

  @@unique([paperId, extractorVersion, sourceTextHash])
  @@index([paperId, status])
  @@index([paperId, createdAt])
}

model PaperClaim {
  id                String                   @id @default(uuid())
  paperId           String
  runId             String
  claimType         String? // coarse category, e.g. factual | methodological | evaluative
  rhetoricalRole    PaperClaimRhetoricalRole
  facet             PaperClaimFacet
  polarity          PaperClaimPolarity
  stance            String? // JSON { subjectText, predicateText, objectText, qualifierText? }
  evaluationContext String? // JSON { task, dataset, metric, comparator, setting, split }
  text              String
  normalizedText    String
  confidence        Float                    @default(0)
  sectionLabel      String?
  sectionPath       String
  sourceExcerpt     String
  excerptHash       String
  sourceSpan        String? // JSON { charStart, charEnd, page? }
  citationAnchors   String? // JSON array of { citationMentionId?, referenceEntryId?, rawMarker }
  evidenceType      PaperClaimEvidenceType
  orderIndex        Int
  createdAt         DateTime                 @default(now())

  paper Paper         @relation(fields: [paperId], references: [id], onDelete: Cascade)
  run   PaperClaimRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([paperId, runId])
  @@index([runId, orderIndex])
  @@index([paperId, rhetoricalRole])
  @@index([paperId, facet])
}

model ConversationArtifact {
  id             String                   @id @default(uuid())
  conversationId String
  messageId      String?
  kind           ConversationArtifactKind
  title          String
  payloadJson    String
  createdAt      DateTime                 @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  message      ChatMessage? @relation(fields: [messageId], references: [id], onDelete: SetNull)

  @@index([conversationId, createdAt])
  @@index([messageId])
}

model PaperRepresentation {
  id                 String   @id @default(uuid())
  paperId            String
  representationKind String
  encoderVersion     String
  sourceFingerprint  String
  dimensions         Int
  featureText        String
  vectorJson         String
  metadataJson       String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  paper Paper @relation(fields: [paperId], references: [id], onDelete: Cascade)

  @@unique([paperId, representationKind])
  @@index([representationKind, updatedAt])
  @@index([representationKind, sourceFingerprint])
}

model Author {
  id                      String   @id @default(uuid())
  canonicalName           String
  normalizedName          String   @unique
  orcid                   String?
  semanticScholarAuthorId String?
  createdAt               DateTime @default(now())

  papers PaperAuthor[]

  @@index([normalizedName])
}

model PaperAuthor {
  id         String   @id @default(uuid())
  paperId    String
  authorId   String
  orderIndex Int
  rawName    String
  createdAt  DateTime @default(now())

  paper  Paper  @relation(fields: [paperId], references: [id], onDelete: Cascade)
  author Author @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@unique([paperId, authorId])
  @@index([authorId, paperId])
}

model NotebookEntry {
  id             String   @id @default(uuid())
  paperId        String
  type           String // "selection" | "explanation" | "chat" | "note"
  selectedText   String?
  content        String?
  annotation     String?
  conversationId String?
  messageId      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  paper        Paper         @relation(fields: [paperId], references: [id], onDelete: Cascade)
  conversation Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
}

model Setting {
  key   String @id
  value String
}

model DiscoverySession {
  id         String   @id @default(uuid())
  userId     String
  title      String?
  status     String   @default("RUNNING") // RUNNING | COMPLETED | FAILED | CANCELLED
  depth      Int      @default(1)
  totalFound Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  owner      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  seedPapers DiscoverySeed[]
  proposals  DiscoveryProposal[]

  @@index([userId])
}

model DiscoverySeed {
  id        String @id @default(uuid())
  sessionId String
  paperId   String

  session DiscoverySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  paper   Paper            @relation(fields: [paperId], references: [id], onDelete: Cascade)

  @@unique([sessionId, paperId])
}

model DiscoveryProposal {
  id                String   @id @default(uuid())
  sessionId         String
  title             String
  authors           String? // JSON array
  year              Int?
  venue             String?
  doi               String?
  arxivId           String?
  externalUrl       String?
  citationCount     Int?
  openAccessPdfUrl  String?
  semanticScholarId String?
  reason            String // "cited_by:<seedPaperId>" or "cites:<seedPaperId>"
  status            String   @default("PENDING") // PENDING | IMPORTED | DISMISSED | ALREADY_IN_LIBRARY
  importedPaperId   String?
  entityId          String?
  createdAt         DateTime @default(now())

  session       DiscoverySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  importedPaper Paper?           @relation(fields: [importedPaperId], references: [id], onDelete: SetNull)
  entity        PaperEntity?     @relation(fields: [entityId], references: [id], onDelete: SetNull)
}

model PaperEngagement {
  id        String   @id @default(uuid())
  paperId   String
  event     String // view, pdf_open, annotate, chat, discovery_seed, import; historical rows may include concept_explore
  createdAt DateTime @default(now())

  paper Paper @relation(fields: [paperId], references: [id], onDelete: Cascade)

  @@index([paperId])
  @@index([paperId, event])
}

model Asset {
