  previewSelectionRun     PreviewSelectionRun @relation(fields: [previewSelectionRunId], references: [id], onDelete: Cascade)
  projectionFigure        ProjectionFigure    @relation(fields: [projectionFigureId], references: [id], onDelete: Cascade)
  selectedAsset           Asset?              @relation("SelectedPreviewAsset", fields: [selectedAssetId], references: [id], onDelete: SetNull)
  selectedRenderedPreview RenderedPreview?    @relation("SelectedRenderedPreview", fields: [selectedRenderedPreviewId], references: [id], onDelete: SetNull)
