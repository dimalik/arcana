  @@index([paperId, canonicalLabelNormalized])
  @@index([identityResolutionId])
}

model FigureIdentityMember {
  id                String   @id @default(uuid())
  figureIdentityId  String
  figureCandidateId String
  createdAt         DateTime @default(now())

  figureIdentity  FigureIdentity  @relation(fields: [figureIdentityId], references: [id], onDelete: Cascade)
  figureCandidate FigureCandidate @relation(fields: [figureCandidateId], references: [id], onDelete: Cascade)

  @@unique([figureIdentityId, figureCandidateId])
  @@index([figureCandidateId])
}

model ProjectionRun {
  id                   String    @id @default(uuid())
  paperId              String
