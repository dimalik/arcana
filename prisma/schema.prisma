  updatedAt                   DateTime @updatedAt

  paper                     Paper                @relation(fields: [paperId], references: [id], onDelete: Cascade)
  activeProjectionRun       ProjectionRun?       @relation("ActiveProjectionRun", fields: [activeProjectionRunId], references: [id], onDelete: SetNull)
  activeIdentityResolution  IdentityResolution?  @relation("ActiveIdentityResolution", fields: [activeIdentityResolutionId], references: [id], onDelete: SetNull)
  activePreviewSelectionRun PreviewSelectionRun? @relation("ActivePreviewSelectionRun", fields: [activePreviewSelectionRunId], references: [id], onDelete: SetNull)

  @@index([activeProjectionRunId])
  @@index([activeIdentityResolutionId])
  @@index([activePreviewSelectionRunId])
}

model PaperMigrationState {
