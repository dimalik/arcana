model PreviewSelectionRun {
  id                              String    @id @default(uuid())
  paperId                         String
  projectionRunId                 String
  selectionKind                   String
  status                          String
  comparisonStatus                String?
  comparisonSummary               String?
  publicationMode                 String?
  metadata                        String?
