  @@index([source, status])
}

model FigureCandidate {
  id                    String   @id @default(uuid())
  paperId               String
  extractionRunId       String?
  bootstrapRunId        String?
  candidateOrigin       String   @default("extracted")
  sourceMethod          String
  type                  String
  sourceLocalLocator    String?
  locatorSupport        String   @default("unsupported")
  sourceNamespace       String?
  sourceOrder           Int      @default(0)
  figureLabelRaw        String?
  figureLabelNormalized String?
  captionTextRaw        String?
  structuredContentRaw  String?
  structuredContentType String?
  nativeAssetId         String?
  nativePreviewTrust    String   @default("none")
  pageAnchorCandidate   String?
  confidence            String?
  diagnostics           String?
